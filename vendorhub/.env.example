# VendorHub — Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# Never commit .env to version control.

# Port to listen on (default: 8080)
PORT=8080

# Comma-separated list of allowed CORS origins for your production domain(s).
# Example: https://vendorhub.yourcompany.com,https://192.168.1.100:8080
VENDORHUB_ALLOWED_ORIGINS=

# Set to "true" if VendorHub runs behind a TLS-terminating reverse proxy
# (nginx, Caddy, etc.). Enables secure cookies and trust proxy.
VENDORHUB_TRUST_PROXY=false
